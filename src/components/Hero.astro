---
// src/components/Hero.astro
---

<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@700&family=Space+Mono&display=swap" rel="stylesheet" />

<section class="hero relative min-h-dvh flex items-center overflow-hidden bg-[#080810]">
  <!-- CAPA 0: El canvas al fondo de todo -->
  <canvas id="heroCanvas" class="absolute inset-0 w-full h-full z-0 cursor-crosshair"></canvas>
  
  <!-- CAPA 1: El degradado encima del canvas pero DEBAJO del texto. Le quitamos el z-[1] y lo dejamos con z-0 o z-10 controlado
  <div class="absolute inset-0 z-1 bg-[radial-gradient(ellipse_at_65%_50%,transparent_20%,#080810_78%)] pointer-events-none"></div>-->

  <!-- CAPA 2: El contenedor de texto con un z-index superior (z-20) para obligarlo a estar al frente -->
  <div class="relative z-20 px-8 md:px-16 lg:px-24 w-full max-w-4xl pointer-events-none">

    <!-- La Caja: Ahora con z-30 y pointer-events-auto explícito en los hijos para asegurar el click/hover -->
    <div class="hero-box relative z-30 flex flex-col gap-0 max-w-[fit-content] pointer-events-auto">

      <!-- Eyebrow — en caja -->
      <p
        id="hero-eyebrow"
        class="hero-spread hero-tool-item font-mono uppercase text-blue opacity-0 cursor-default
               text-[0.95rem] tracking-[0.4em] mb-4 w-full"
        data-es="Realizadora audiovisual & VJ"
        data-en="Audiovisual Director & VJ"
      >Realizadora audiovisual & VJ</p>

      <!-- Name — Ahora le añadimos la clase 'relative z-40' para aislarlo por completo en su propia capa interactiva -->
      <h1
        id="hero-name"
        class="hero-title relative z-40 opacity-0 cursor-pointer block mb-2"
        style="font-family: 'Open Sans', sans-serif; font-weight: 700; font-size: clamp(3.5rem, 8vw, 6.5rem); line-height: 0.85;">
        <span class="block pointer-events-auto">Victoria</span>
        <span class="block pointer-events-auto">Melina</span>
      </h1>

      <!-- Alias -->
      <p
        id="hero-alias"
        class="hero-spread font-mono tracking-[0.2em] text-violet/60 opacity-0 cursor-default
               text-[1.1rem] mt-2 mb-6 w-full"
      >VJ Bluh</p>

      <!-- Tagline -->
      <p
  id="hero-tagline"
        class="hero-tool-item hero-spread font-mono uppercase opacity-0 cursor-default
               text-[1.2rem] mb-6 w-full"
        data-es="Creo imágenes que se mueven en tiempo real."
        data-en="I make images that move in real time."
      >Creo imágenes que se mueven en tiempo real.</p>

      <!-- Tools — Forzamos que cada elemento interno escuche los eventos del mouse -->
      <!-- Tools — Vertical en mobile, horizontal justificado en desktop -->
      <div
        id="hero-tools"
        class="flex flex-col md:flex-row md:justify-between gap-3 md:gap-4 w-full font-mono uppercase text-muted opacity-0
               text-[0.95rem] tracking-[0.1em] mb-8 relative z-40 pointer-events-auto">
        <span class="hero-tool-item cursor-pointer pointer-events-auto">After Effects</span>
        <span class="hero-tool-item cursor-pointer pointer-events-auto">TouchDesigner</span>
        <span class="hero-tool-item cursor-pointer pointer-events-auto">Resolume</span>
      </div>

      

    </div>
  </div>

  <!-- Scroll indicator -->
  <div id="hero-scroll" class="absolute bottom-8 left-8 md:left-16 lg:left-24 z-20 opacity-0 pointer-events-none flex items-center gap-3">
    <div class="w-12 h-px overflow-hidden">
      <div id="scrollLine" class="w-full h-full bg-gradient-to-r from-transparent to-violet origin-left"></div>
    </div>
    <span class="font-mono text-[0.65rem] tracking-[0.15em] uppercase text-muted" data-es="scroll" data-en="scroll">scroll</span>
  </div>
</section>



<script>
  import { gsap } from 'gsap';

  // ─── CANVAS (Partículas más grandes) ───────────────────────────────────────
  const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0;

  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    size: number; alpha: number;
    hue: number; sat: number; lit: number;
    life: number; maxLife: number;
    drag?: number;
  }

  let particles: Particle[] = [];
  function rand(a: number, b: number) { return a + Math.random() * (b - a); }

  function makeParticle(): Particle {
    const angle = Math.random() * Math.PI * 2;
    const speed = rand(0.05, 0.3); // Un poco más lentas para equilibrar el tamaño masivo
    const hue   = Math.random() < 0.6 ? 270 : 190;
    return {
      x: Math.random() * W, y: Math.random() * H,
      vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
      size: rand(8, 22), // 🌟 Partículas base MÁS GRANDES (Antes: 3 a 8)
      alpha: rand(0.15, 0.55), // Un poco más transparentes para que no saturen por su tamaño
      hue, sat: rand(70, 100), lit: rand(50, 75),
      life: 0, maxLife: rand(300, 800),
    };
  }

  function makeBurstParticle(x: number, y: number): Particle {
    const angle = Math.random() * Math.PI * 2;
    const speed = rand(2, 6);
    const hue   = Math.random() < 0.5 ? 270 : 190;
    return {
      x, y,
      vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
      size: rand(12, 28), // 🌟 Partículas de explosión MÁS GRANDES (Antes: 4 a 9)
      alpha: rand(0.6, 0.9),
      hue, sat: 100, lit: rand(65, 85),
      life: 0, maxLife: rand(50, 100), drag: 0.93,
    };
  }

  function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  function initParticles() {
    // Reducimos un poco la densidad para que las partículas grandes respiren mejor
    const count = Math.min(Math.floor((W * H) / 9000), 120);
    particles = Array.from({ length: count }, makeParticle);
  }

  const REPEL_RADIUS = 180, REPEL_FORCE = 5, BURST_COUNT = 14;
  const HOVER_RADIUS = 110,  HOVER_FORCE = 0.3;

  canvas.addEventListener('click', (e: MouseEvent) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    particles.forEach(p => {
      const dx = p.x - mx, dy = p.y - my;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < REPEL_RADIUS && dist > 0) {
        const force = (1 - dist / REPEL_RADIUS) * REPEL_FORCE;
        p.vx += (dx/dist)*force; p.vy += (dy/dist)*force;
        p.life = 0; p.maxLife = rand(300, 600);
      }
    });
    particles.push(...Array.from({ length: BURST_COUNT }, () => makeBurstParticle(mx, my)));
  });

  canvas.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    particles.forEach(p => {
      const dx = p.x - mx, dy = p.y - my;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < HOVER_RADIUS && dist > 0) {
        const force = (1 - dist / HOVER_RADIUS) * HOVER_FORCE;
        p.vx += (dx/dist)*force; p.vy += (dy/dist)*force;
      }
    });
  });

  function drawFrame() {
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = 'rgba(8,8,16,0.15)';
    ctx.fillRect(0, 0, W, H);

    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.life++;
      if (p.drag !== undefined) { p.vx *= p.drag; p.vy *= p.drag; }
      p.x += p.vx; p.y += p.vy;
      const progress = p.life / p.maxLife;
      const fade = progress < 0.1 ? progress/0.1 : progress > 0.8 ? (1-progress)/0.2 : 1;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${p.hue},${p.sat}%,${p.lit}%,${p.alpha * fade})`;
      ctx.fill();
      if (p.life >= p.maxLife) {
        if (p.drag !== undefined) particles.splice(i, 1);
        else particles[i] = makeParticle();
      } else if (p.drag === undefined && (p.x < -20 || p.x > W+20 || p.y < -20 || p.y > H+20)) {
        particles[i] = makeParticle();
      }
    }

    const ambient = particles.filter(p => p.drag === undefined);
    for (let i = 0; i < ambient.length; i++) {
      for (let j = i + 1; j < ambient.length; j++) {
        const dx = ambient[i].x - ambient[j].x, dy = ambient[i].y - ambient[j].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < 130) {
          ctx.beginPath();
          ctx.moveTo(ambient[i].x, ambient[i].y);
          ctx.lineTo(ambient[j].x, ambient[j].y);
          ctx.strokeStyle = `rgba(123,47,255,${0.06*(1-dist/130)})`;
          ctx.lineWidth = 0.8; ctx.stroke();
        }
      }
    }
    requestAnimationFrame(drawFrame);
  }

  function startCanvas() { resize(); initParticles(); drawFrame(); }
  window.addEventListener('resize', () => { resize(); initParticles(); }, { passive: true });
  startCanvas();

  // ─── GSAP entrance ────────────────────────────────────────────────────────
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReduced) {
    gsap.set(['#hero-eyebrow','#hero-name','#hero-alias','#hero-tagline','#hero-tools','#hero-cta','#hero-scroll'], { opacity: 1 });
  } else {
    const tl = gsap.timeline({ delay: 0.2 });
    tl.fromTo('#hero-eyebrow',  { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' })
      .fromTo('#hero-name',     { opacity: 0, x: -40 }, { opacity: 1, x: 0, duration: 0.9, ease: 'power3.out' }, '-=0.1')
      .fromTo('#hero-alias',    { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .fromTo('#hero-tagline',  { opacity: 0, x: -16 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2')
      .fromTo('#hero-tools',    { opacity: 0 },          { opacity: 1, duration: 0.5, ease: 'power1.out' },       '-=0.1')
      //.fromTo('#hero-cta',      { opacity: 0, y: 10 },  { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2')
      .fromTo('#hero-scroll',   { opacity: 0 },          { opacity: 1, duration: 0.4 },                           '-=0.1');

    gsap.fromTo('#scrollLine',
      { scaleX: 0, transformOrigin: 'left' },
      { scaleX: 1, duration: 1, ease: 'power1.inOut', repeat: -1, yoyo: true, delay: 1.5 }
    );
  }

  // ─── Lang sync ────────────────────────────────────────────────────────────
  function applyLangToHero(lang: 'es' | 'en') {
    document.querySelectorAll<HTMLElement>('#hero-eyebrow, #hero-tagline, #hero-cta a, #hero-scroll span').forEach(el => {
      const val = el.dataset[lang];
      if (val) el.textContent = val;
    });
  }
  const saved = (localStorage.getItem('lang') as 'es' | 'en' | null) ?? 'es';
  applyLangToHero(saved);
  window.addEventListener('langchange', (e: Event) => {
    const { lang } = (e as CustomEvent<{ lang: 'es' | 'en' }>).detail;
    applyLangToHero(lang);
  });
</script>